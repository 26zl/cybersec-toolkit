flowchart TB
    clients["MCP / Agent Skills clients"]:::actor
    configs["Client configurations"]:::core
    launcher["scripts/mcp-launch.sh<br/>root-aware launcher"]:::core

    clients --> configs --> launcher

    subgraph MCP["FastMCP server"]
        direction TB
        gateway["MCP transport and tool API"]:::core
        advisors["Discovery and advisors"]:::core
        governed["Governed tool execution<br/>run_tool · run_pipeline"]:::security
        scripts["Opt-in script execution<br/>run_script"]:::optin
        remote["Authorized remote hosts"]:::core

        gateway --> advisors
        gateway --> governed
        gateway --> scripts
        governed --> remote
    end

    launcher --> gateway

    subgraph INSTALLER["Tool installation"]
        direction TB
        operator(["Operator"]):::actor
        installer["install.sh and module installers"]:::core
        registry[("tools_config.json<br/>tool registry")]:::data
        installed[("Installed security tools")]:::data

        operator --> installer
        installer --> registry
        installer --> installed
    end

    registry --> advisors
    registry --> governed
    governed --> installed

    subgraph SKILLS["Agent Skills"]
        direction LR
        source[".claude/skills/<br/>source of truth"]:::skill
        sync["scripts/sync-skills.sh"]:::core
        mirror[".agents/skills/<br/>generated mirror"]:::skill

        source --> sync --> mirror
    end

    source -. "native client discovery" .-> clients
    mirror -. "portable client discovery" .-> clients

    ci["CI validation<br/>shell and Bats · registry and MCP<br/>Ruff and Pytest · skills and pins<br/>agent docs and client configs"]:::ci
    ci -.-> registry
    ci -.-> gateway
    ci -.-> source

