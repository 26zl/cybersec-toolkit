# Force LF line endings for all text files in this repo.
# Prevents CRLF breakage when shell scripts are checked out on Windows.
* text=auto eol=lf

# Explicitly mark script types as text (safety net)
*.sh text eol=lf
*.bats text eol=lf
*.conf text eol=lf
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf

# Keep repository quality tooling in Git, but omit it from GitHub source
# archives intended for end users.
.github/ export-ignore
tests/ export-ignore
mcp_server/tests/ export-ignore
.gitmodules export-ignore
.gitleaks.toml export-ignore
.markdownlint.jsonc export-ignore
scripts/audit_skill_dependencies.py export-ignore
scripts/curate_claude_skills.py export-ignore
scripts/validate_claude_skills.py export-ignore
scripts/validate_distro_compat.py export-ignore
scripts/validate_mcp_sync.py export-ignore
scripts/validate_tools_config.py export-ignore
